########################################################################
# REQUIRED
########################################################################

GROQ_API_KEY=your_groq_api_key_here
# Free key at: https://console.groq.com

########################################################################
# OPTIONAL — LangSmith run tracing
########################################################################

# Free personal key at: https://smith.langchain.com  (Settings → API Keys)
# Use a personal/workspace-scoped key, not an org-scoped key
# LANGSMITH_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=hospitality-multi-agent

########################################################################
# OPTIONAL — override agent server URLs (defaults shown)
########################################################################

# BI_AGENT_URL=http://127.0.0.1:8001
# MEDIA_AGENT_URL=http://127.0.0.1:8002
# PRICING_AGENT_URL=http://127.0.0.1:8003
# COORDINATOR_AGENT_URL=http://127.0.0.1:8004
