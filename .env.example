########################################################################
# REQUIRED — needed to run the project locally right now
########################################################################

GROQ_API_KEY=your_groq_api_key_here
# Get a free key at: https://console.groq.com

########################################################################
# OPTIONAL — only needed when deploying agents independently (USE_REMOTE=true)
########################################################################

# false = local in-process functions (default, works out of the box)
# true  = RemoteGraph HTTP calls    (requires agents deployed as servers)
USE_REMOTE=false

# Only needed when agents are hosted on LangSmith Platform (paid/free tier)
# For self-hosted deployments (Docker, Railway, Render) leave this unset
# Free account: https://smith.langchain.com
# LANGSMITH_API_KEY=your_langsmith_api_key_here

# Agent server URLs — set these when USE_REMOTE=true
# Local simulation: run each agent with `langgraph dev --port 800X`
# BI_AGENT_URL=http://localhost:8001
# MEDIA_AGENT_URL=http://localhost:8002
# PRICING_AGENT_URL=http://localhost:8003
# COORDINATOR_AGENT_URL=http://localhost:8004
